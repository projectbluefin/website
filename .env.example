# Wolves cinematic OAuth configuration.
# Copy to .env.local and fill in real client ids. Both providers are public
# browser clients: no secrets belong in this file or anywhere in the repo.

# Google Cloud Console > Credentials > OAuth 2.0 Client ID (Web application).
# Add the deployment origin (https://wolves.projectbluefin.io) and
# http://localhost:5173 to "Authorized JavaScript origins".
VITE_GOOGLE_CLIENT_ID=

# Spotify Developer Dashboard > App > Client ID.
# Add the exact redirect URI below to the app's Redirect URIs list.
VITE_SPOTIFY_CLIENT_ID=

# Where Spotify redirects back to after consent. Must match the dashboard entry
# exactly. Defaults to the current page URL when unset.
VITE_OAUTH_REDIRECT_URI=https://wolves.projectbluefin.io/wolves/
